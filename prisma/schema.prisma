generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  username       String    @unique
  passwordHash   String
  role           String    @default("MEMBRE")
  sessionVersion Int       @default(0)
  createdAt      DateTime  @default(now())
  logs           Log[]     @relation("Author")
  reverts        Log[]     @relation("Reverter")
  rapports       Rapport[] @relation("RapportAuteur")
  rapportsRevus  Rapport[] @relation("RapportRevieweur")
}

model Rapport {
  id           Int       @id @default(autoincrement())
  userId       Int
  user         User      @relation("RapportAuteur", fields: [userId], references: [id], onDelete: Cascade)
  type         String    // PARTICIPATION | ORGANISATION | RECRUTEMENT
  weekStart    DateTime  // Vendredi de la semaine (ven→jeu), UTC midnight
  description  String
  status       String    @default("EN_ATTENTE") // EN_ATTENTE | APPROUVE | REJETE
  reviewNote   String?
  reviewedById Int?
  reviewedBy   User?     @relation("RapportRevieweur", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
}

model Log {
  id             Int       @id @default(autoincrement())
  userId         Int?
  user           User?     @relation("Author", fields: [userId], references: [id], onDelete: SetNull)
  username       String    @default("Système")
  action         String    // create | update | delete | import | revert
  entity         String    // ninja | donation | tax | settings | grades | import
  entityId       Int?
  entityName     String?
  description    String
  diff           String?   // JSON
  sessionId      String?   // groups import entries
  reverted       Boolean   @default(false)
  revertedAt     DateTime?
  revertedById   Int?
  revertedBy     User?     @relation("Reverter", fields: [revertedById], references: [id], onDelete: SetNull)
  revertedByName String?
  revertReason   String?
  isOrphaned     Boolean   @default(false)
  isCascade      Boolean   @default(false)
  parentLogId    Int?
  createdAt      DateTime  @default(now())
}

model Ninja {
  id           Int        @id @default(autoincrement())
  name         String
  points       Float      @default(0)
  exonerations Float      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  donations    Donation[]
  taxes        Tax[]
}

model Donation {
  id                Int      @id @default(autoincrement())
  ninjaId           Int
  ninja             Ninja    @relation(fields: [ninjaId], references: [id], onDelete: Cascade)
  resource          String
  amount            Float    @default(0)
  pointsEarned      Float    @default(0)
  exonerationEarned Float    @default(0)
  createdAt         DateTime @default(now())
}

model Tax {
  id        Int      @id @default(autoincrement())
  ninjaId   Int
  ninja     Ninja    @relation(fields: [ninjaId], references: [id], onDelete: Cascade)
  weekStart DateTime
  paid      Boolean  @default(false)

  @@unique([ninjaId, weekStart])
}

model ResourceValue {
  resource           String   @id
  pointsPerUnit      Float    @default(1)
  exonerationPerUnit Float    @default(0)
  updatedAt          DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}

model RachatEquipement {
  id        Int      @id @default(autoincrement())
  nom       String
  categorie String   // T1 | T2 | T3 | T4
  prixPlan  Float?
  prixCraft Float?
  situation String   @default("Non Besoin")
  createdAt DateTime @default(now())
}

model RachatRessource {
  id            Int      @id @default(autoincrement())
  nom           String
  prixRachatMax Float?
  situation     String   @default("Non Besoin")
  createdAt     DateTime @default(now())
}
