# Chemin vers la base de données SQLite
# En production sur Coolify, pointer vers un volume persistant
DATABASE_URL="file:./dev.db"

# Mot de passe pour accéder au site
SITE_PASSWORD="changeme"

# Clé secrète pour les sessions (minimum 32 caractères)
SESSION_SECRET="changez-cette-cle-secrete-en-production-32chars"
